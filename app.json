{
  "expo": {
    "name": "Visitor Log System",
    "slug": "visitor-log-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "visitorlogapp",
    "userInterfaceStyle": "automatic",

    "ios": {
      "bundleIdentifier": "com.anonymous.visitorlogapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to capture visitor photos and ID cards.",
        "NSPhotoLibraryUsageDescription": "This app uses the photo library to select visitor photos and ID cards."
      }
    },

    "android": {
      "package": "com.anonymous.visitorlogapp",

      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],

      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],

      "expo-sharing"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa28c0eb-b162-426b-8e61-d21da4387960"
      }
    }
  }
}